{
  "version": 4,
  "include": ["./ConanPresets.json"],
  "configurePresets": [
    {
      "name": "release",
      "displayName": "release single config (ninja)",
      "inherits": "conan-release",
      "cacheVariables": {
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/CSP-WASM-Bindings",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "debug single config (ninja)",
      "inherits": "conan-debug",
      "cacheVariables": {
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/CSP-WASM-Bindings",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "release",
      "configurePreset": "release",
      "configuration": "Release"
    },
    {
      "name": "debug",
      "configurePreset": "debug",
      "configuration": "Debug"
    }
  ]
}
