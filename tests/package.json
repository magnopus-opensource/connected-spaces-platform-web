    "lint": "eslint ."
  },
  "devDependencies": {
    "@vitest/browser": "4.1.6",
    "@vitest/browser-playwright": "4.1.6",
    "@vitest/eslint-plugin": "1.3.16",
    "eslint": "9.36.0",
    "playwright": "1.59.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.46.4",
    "vitest": "4.1.6"
  }
}
