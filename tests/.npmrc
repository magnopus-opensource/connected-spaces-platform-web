save-exact=true

# Supply-chain hardening.
# Refuse to install package versions younger than 7 days. Window for malicious
# releases to be detected and yanked before they land in our builds. Requires
# npm >= 11.5.1.
minimum-release-age=10080

# Refuse to run pre/post install lifecycle scripts from any package (including
# this one). Neutralises the most common payload vector in npm supply-chain
# attacks.
ignore-scripts=true
