{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["vitest/globals", "@vitest/browser/providers/playwright"],
    "paths": {
      //Terrible hard-coded, this is really just for autocomplete
      "connected-spaces-platform-bindings": ["../CSP-WASM-Bindings/connected-spaces-platform-bindings.d.ts"]
    }
  },
  "include": ["**/*.ts"]
}
